rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trainingUsers/{userId} {
      // Employees can create, read, and update only their own training record.
      allow create, read, update: if request.auth != null
                                  && request.auth.uid == userId;

      // IMPORTANT: Replace the address below with your exact admin login email.
      // Add additional quoted addresses separated by commas when needed.
      allow read: if request.auth != null
                  && request.auth.token.email in [
                    'rjean@etr.ca'
                  ];

      allow delete: if false;
    }
  }
}

